# Copy this file to infra/compose/.env before starting the data platform.
# These values are for local development only. Replace every secret in shared environments.

POSTGRES_DB=atlas_rag
POSTGRES_USER=atlas
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_PORT=5432

ELASTIC_PASSWORD=change-me-elastic
ELASTICSEARCH_PORT=9200

NEO4J_PASSWORD=change-me-neo4j
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

REDIS_PASSWORD=change-me-redis
REDIS_PORT=6379

MINIO_ROOT_USER=atlas
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_QUARANTINE_BUCKET=atlas-rag-quarantine
MINIO_DOCUMENT_BUCKET=atlas-rag-documents
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

CLAMAV_PORT=3310

AI_SERVICE_PORT=8001
